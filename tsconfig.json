{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "types": ["node"],
    "typeRoots": ["./node_modules/@types", "./infra"]
  },
  "include": ["infra/**/*", "packages/**/*", "sst.config.ts", "sst-env.d.ts"]
}
